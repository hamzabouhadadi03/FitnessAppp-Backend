# =============================================================================
# FitProgress Backend — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# Application
APP_NAME=FitProgress
APP_ENV=development          # development | production
DEBUG=true                   # false in production
SECRET_KEY=                  # random 64-char hex string: openssl rand -hex 32

# Database
DATABASE_URL=                # postgresql+asyncpg://user:pass@localhost:5432/fitprogress
POSTGRES_USER=fitprogress
POSTGRES_PASSWORD=           # strong random password
POSTGRES_DB=fitprogress
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=                   # redis://localhost:6379/0

# Auth0
AUTH0_DOMAIN=dev-ira3ehse2ti37nl8.us.auth0.com                # your-tenant.auth0.com (no https://)
AUTH0_AUDIENCE=https://api.fitprogress.com              # your API identifier registered in Auth0 dashboard
AUTH0_ALGORITHMS=RS256       # do not change

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Logging
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# =============================================================================
# Celery — tâches asynchrones (broker + backend = Redis)
# =============================================================================
# Laisser vide pour utiliser REDIS_URL automatiquement
CELERY_BROKER_URL=           # redis://redis:6379/1 (base 1 pour isoler des données app)
CELERY_RESULT_BACKEND=       # redis://redis:6379/1

# =============================================================================
# Push Notifications — APNs (iOS)
# Obtenir depuis : https://developer.apple.com → Certificates, IDs & Profiles
# =============================================================================
APNS_ENABLED=false           # true pour activer l'envoi réel
APNS_KEY_ID=                 # 10 caractères, ex : ABC1234DEF
APNS_TEAM_ID=                # 10 caractères, ex : XYZ9876WVU
APNS_BUNDLE_ID=              # Bundle ID de l'app iOS, ex : com.fitprogress.app
APNS_PRIVATE_KEY=            # Contenu complet du fichier .p8 (avec header/footer BEGIN PRIVATE KEY)

# =============================================================================
# Push Notifications — FCM (Android)
# Obtenir depuis : Firebase Console → Project Settings → Service Accounts
# =============================================================================
FCM_ENABLED=false            # true pour activer l'envoi réel
FCM_PROJECT_ID=              # Firebase project ID, ex : fitprogress-prod
FCM_SERVICE_ACCOUNT_JSON=    # JSON complet du service account (sur une ligne, échappé)
